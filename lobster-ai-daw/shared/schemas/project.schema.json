{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MusicProject",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "bpm": { "type": "number" },
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "instrument": { "type": "string" },
          "volume": { "type": "number" },
          "isMuted": { "type": "boolean" },
          "isSolo": { "type": "boolean" }
        },
        "required": ["id", "name", "instrument"]
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "trackId": { "type": "string" },
          "name": { "type": "string" },
          "prompt": { "type": "string" },
          "bpm": { "type": "number" },
          "duration": { "type": "number" },
          "startOffset": { "type": "number" },
          "audioUrl": { "type": "string" }
        },
        "required": ["id", "trackId", "prompt", "duration"]
      }
    }
  },
  "required": ["id", "name", "bpm", "tracks", "blocks"]
}
